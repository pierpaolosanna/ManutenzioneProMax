# ============================================================
# MAS.psm1 - Modulo per Microsoft Activation Scripts (MAS)
# Versione: 1.0.1 - Password dialog (non bloccante)
# ============================================================

Add-Type -AssemblyName System.IO.Compression

function Invoke-MASActivation {
    # Crea un form per la password
    $passwordForm = New-Object System.Windows.Forms.Form
    $passwordForm.Text = "🔑 MAS Activation - Inserisci Password"
    $passwordForm.Size = New-Object System.Drawing.Size(360, 160)
    $passwordForm.StartPosition = "CenterParent"
    $passwordForm.FormBorderStyle = "FixedDialog"
    $passwordForm.MaximizeBox = $false
    $passwordForm.MinimizeBox = $false
    $passwordForm.BackColor = [System.Drawing.Color]::FromArgb(28, 28, 34)
    $passwordForm.ForeColor = [System.Drawing.Color]::White
    $passwordForm.Font = New-Object System.Drawing.Font("Segoe UI", 10)
    $passwordForm.TopMost = $true

    # Etichetta
    $label = New-Object System.Windows.Forms.Label
    $label.Text = "Inserisci la password per sbloccare MAS:"
    $label.Location = New-Object System.Drawing.Point(20, 20)
    $label.Size = New-Object System.Drawing.Size(310, 25)
    $label.ForeColor = [System.Drawing.Color]::White
    $passwordForm.Controls.Add($label)

    # Campo password
    $textBox = New-Object System.Windows.Forms.TextBox
    $textBox.Location = New-Object System.Drawing.Point(20, 55)
    $textBox.Size = New-Object System.Drawing.Size(310, 26)
    $textBox.PasswordChar = '*'
    $textBox.BackColor = [System.Drawing.Color]::FromArgb(36, 36, 42)
    $textBox.ForeColor = [System.Drawing.Color]::White
    $textBox.Font = New-Object System.Drawing.Font("Segoe UI", 11)
    $passwordForm.Controls.Add($textBox)

    # Pulsanti
    $btnOK = New-Object System.Windows.Forms.Button
    $btnOK.Text = "OK"
    $btnOK.Location = New-Object System.Drawing.Point(170, 95)
    $btnOK.Size = New-Object System.Drawing.Size(75, 28)
    $btnOK.BackColor = [System.Drawing.Color]::FromArgb(0, 160, 0)
    $btnOK.ForeColor = [System.Drawing.Color]::White
    $btnOK.FlatStyle = "Flat"
    $btnOK.DialogResult = [System.Windows.Forms.DialogResult]::OK
    $btnOK.Cursor = [System.Windows.Forms.Cursors]::Hand
    $passwordForm.Controls.Add($btnOK)
    $passwordForm.AcceptButton = $btnOK

    $btnCancel = New-Object System.Windows.Forms.Button
    $btnCancel.Text = "Annulla"
    $btnCancel.Location = New-Object System.Drawing.Point(255, 95)
    $btnCancel.Size = New-Object System.Drawing.Size(75, 28)
    $btnCancel.BackColor = [System.Drawing.Color]::FromArgb(220, 60, 60)
    $btnCancel.ForeColor = [System.Drawing.Color]::White
    $btnCancel.FlatStyle = "Flat"
    $btnCancel.DialogResult = [System.Windows.Forms.DialogResult]::Cancel
    $btnCancel.Cursor = [System.Windows.Forms.Cursors]::Hand
    $passwordForm.Controls.Add($btnCancel)
    $passwordForm.CancelButton = $btnCancel

    # Mostra il form e ottieni il risultato
    $result = $passwordForm.ShowDialog()
    if ($result -ne [System.Windows.Forms.DialogResult]::OK) {
        Log "[i] MAS annullato."
        return
    }

    $password = $textBox.Text
    if ([string]::IsNullOrEmpty($password)) {
        Log "[X] Password non inserita."
        return
    }

    # Dati crittografati (Base64) - GENERATO AUTOMATICAMENTE
    $encryptedBase64 = ""

    try {
        $combined = [Convert]::FromBase64String($encryptedBase64)
        if ($combined.Length -lt 32) { throw "Dati corrotti" }

        $salt = $combined[0..15]
        $iv = $combined[16..31]
        $ciphertext = $combined[32..$combined.Length]

        # Deriva la chiave
        $pbkdf2 = New-Object System.Security.Cryptography.Rfc2898DeriveBytes($password, $salt, 100000)
        $key = $pbkdf2.GetBytes(32)

        # Decrittazione
        $aes = [System.Security.Cryptography.Aes]::Create()
        $aes.Key = $key
        $aes.IV = $iv
        $decryptor = $aes.CreateDecryptor()
        $plainCompressed = $decryptor.TransformFinalBlock($ciphertext, 0, $ciphertext.Length)

        # Decompressione (con sintassi corretta per MemoryStream)
        $ms = New-Object System.IO.MemoryStream -ArgumentList (,$plainCompressed)
        $gz = New-Object System.IO.Compression.GZipStream($ms, [System.IO.Compression.CompressionMode]::Decompress)
        $outMs = New-Object System.IO.MemoryStream
        $gz.CopyTo($outMs)
        $gz.Close()
        $ms.Close()
        $plainBytes = $outMs.ToArray()
        $outMs.Close()

        # Salva su file temporaneo
        $tempFile = [System.IO.Path]::GetTempFileName() + ".cmd"
        [System.IO.File]::WriteAllBytes($tempFile, $plainBytes)

        # Avvia il processo
        Log "[OK] Avvio MAS..."
        Start-Process -FilePath $tempFile -Wait -WindowStyle Normal

        # Rimuovi il file temporaneo dopo l'esecuzione
        Remove-Item -Path $tempFile -Force -ErrorAction SilentlyContinue

    } catch [System.Security.Cryptography.CryptographicException] {
        Log "[X] Password errata o dati corrotti." -ForegroundColor Red
    } catch {
        Log "[X] Errore: $($_.Exception.Message)" -ForegroundColor Red
    }
}

Export-ModuleMember -Function Invoke-MASActivation